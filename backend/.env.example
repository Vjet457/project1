# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/aarogyasaathi

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=30d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:8081

# Twilio SMS delivery for SOS alerts (optional until you configure a provider)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_FROM_NUMBER=

# Google Gemini AI (for AI symptom analysis)
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
